{
  "UserDetailList": [

    {
      "UserName": "HelpDeskUser",
      "UserPolicyList": [
        {
          "PolicyDocument": {
            "Statement": [{
              "Effect": "Allow",
              "Action": "sts:AssumeRole",
              "Resource": [
                "arn:aws:iam::100000000001:role/SupportRole",
                "arn:aws:iam::100000000001:role/AuditRole"
              ]
            }]
          }
        }
      ]
    },

    {
      "UserName": "DevUser",
      "UserPolicyList": [
        {
          "PolicyDocument": {
            "Statement": [{
              "Effect": "Allow",
              "Action": "sts:AssumeRole",
              "Resource": "arn:aws:iam::100000000001:role/DeveloperRole"
            }]
          }
        }
      ]
    },

    {
      "UserName": "ContractorUser",
      "UserPolicyList": [
        {
          "PolicyDocument": {
            "Statement": [{
              "Effect": "Allow",
              "Action": "sts:AssumeRole",
              "Resource": "arn:aws:iam::100000000002:role/TempAccessRole"
            }]
          }
        }
      ]
    }

  ],

  "RoleDetailList": [


    {
      "RoleName": "SupportRole",
      "Arn": "arn:aws:iam::100000000001:role/SupportRole",
      "AssumeRolePolicyDocument": {
        "Statement": [{
          "Effect": "Allow",
          "Principal": { "AWS": "arn:aws:iam::100000000001:user/HelpDeskUser" },
          "Action": "sts:AssumeRole"
        }]
      },
      "RolePolicyList": [{
        "PolicyDocument": {
          "Statement": [{
            "Effect": "Allow",
            "Action": "sts:AssumeRole",
            "Resource": "arn:aws:iam::100000000001:role/DevOpsRole"
          }]
        }
      }]
    },

    {
      "RoleName": "DeveloperRole",
      "Arn": "arn:aws:iam::100000000001:role/DeveloperRole",
      "AssumeRolePolicyDocument": {
        "Statement": [{
          "Effect": "Allow",
          "Principal": { "AWS": "arn:aws:iam::100000000001:user/DevUser" },
          "Action": "sts:AssumeRole"
        }]
      },
      "RolePolicyList": [{
        "PolicyDocument": {
          "Statement": [{
            "Effect": "Allow",
            "Action": [
              "iam:PassRole",
              "ec2:RunInstances"
            ],
            "Resource": "*"
          }]
        }
      }]
    },

    {
      "RoleName": "DevOpsRole",
      "Arn": "arn:aws:iam::100000000001:role/DevOpsRole",
      "AssumeRolePolicyDocument": {
        "Statement": [{
          "Effect": "Allow",
          "Principal": { "AWS": "arn:aws:iam::100000000001:role/SupportRole" },
          "Action": "sts:AssumeRole"
        }]
      },
      "RolePolicyList": [{
        "PolicyDocument": {
          "Statement": [{
            "Effect": "Allow",
            "Action": [
              "iam:PassRole",
              "lambda:CreateFunction"
            ],
            "Resource": "*"
          }]
        }
      }]
    },

    {
      "RoleName": "EC2AdminExecutionRole",
      "Arn": "arn:aws:iam::100000000001:role/EC2AdminExecutionRole",
      "AssumeRolePolicyDocument": {
        "Statement": [{
          "Effect": "Allow",
          "Principal": { "Service": "ec2.amazonaws.com" },
          "Action": "sts:AssumeRole"
        }]
      },
      "AttachedManagedPolicies": [{
        "PolicyName": "AdministratorAccess",
        "PolicyArn": "arn:aws:iam::aws:policy/AdministratorAccess"
      }]
    },

    {
      "RoleName": "LambdaAdminExecutionRole",
      "Arn": "arn:aws:iam::100000000001:role/LambdaAdminExecutionRole",
      "AssumeRolePolicyDocument": {
        "Statement": [{
          "Effect": "Allow",
          "Principal": { "Service": "lambda.amazonaws.com" },
          "Action": "sts:AssumeRole"
        }]
      },
      "AttachedManagedPolicies": [{
        "PolicyName": "AdministratorAccess",
        "PolicyArn": "arn:aws:iam::aws:policy/AdministratorAccess"
      }]
    },

    {
      "RoleName": "AuditRole",
      "Arn": "arn:aws:iam::100000000001:role/AuditRole",
      "AssumeRolePolicyDocument": {
        "Statement": [{
          "Effect": "Allow",
          "Principal": { "AWS": "arn:aws:iam::100000000001:user/HelpDeskUser" },
          "Action": "sts:AssumeRole"
        }]
      },
      "RolePolicyList": [{
        "PolicyDocument": {
          "Statement": [{
            "Effect": "Allow",
            "Action": "logs:DescribeLogGroups",
            "Resource": "*"
          }]
        }
      }]
    },


    {
      "RoleName": "TempAccessRole",
      "Arn": "arn:aws:iam::100000000002:role/TempAccessRole",
      "AssumeRolePolicyDocument": {
        "Statement": [{
          "Effect": "Allow",
          "Principal": { "AWS": "arn:aws:iam::100000000002:user/ContractorUser" },
          "Action": "sts:AssumeRole"
        }]
      },
      "RolePolicyList": [{
        "PolicyDocument": {
          "Statement": [{
            "Effect": "Allow",
            "Action": "sts:AssumeRole",
            "Resource": "arn:aws:iam::100000000003:role/ProdPivotRole"
          }]
        }
      }]
    },


    {
      "RoleName": "ProdPivotRole",
      "Arn": "arn:aws:iam::100000000003:role/ProdPivotRole",
      "AssumeRolePolicyDocument": {
        "Statement": [{
          "Effect": "Allow",
          "Principal": { "AWS": "arn:aws:iam::100000000002:role/TempAccessRole" },
          "Action": "sts:AssumeRole"
        }]
      },
      "RolePolicyList": [{
        "PolicyDocument": {
          "Statement": [{
            "Effect": "Allow",
            "Action": "sts:AssumeRole",
            "Resource": "arn:aws:iam::100000000003:role/ProductionAdminRole"
          }]
        }
      }]
    },

    {
      "RoleName": "ProductionAdminRole",
      "Arn": "arn:aws:iam::100000000003:role/ProductionAdminRole",
      "AssumeRolePolicyDocument": {
        "Statement": [{
          "Effect": "Allow",
          "Principal": { "AWS": "arn:aws:iam::100000000003:role/ProdPivotRole" },
          "Action": "sts:AssumeRole"
        }]
      },
      "AttachedManagedPolicies": [{
        "PolicyName": "AdministratorAccess",
        "PolicyArn": "arn:aws:iam::aws:policy/AdministratorAccess"
      }]
    }

  ]
}