# ── IAM Defender — Environment Configuration ─────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Flask session secret key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
IAM_SECRET_KEY=change-me-to-a-random-secret

# Web app login credentials
IAM_ADMIN_USER=admin
IAM_ADMIN_PASSWORD=changeme

# Logging level: DEBUG | INFO | WARNING | ERROR
IAM_LOG_LEVEL=INFO

# Web server port
PORT=5000

# AI-powered remediation (Google Gemini — free tier at aistudio.google.com)
GEMINI_API_KEY=

# AWS credentials (for --live mode in main.py)
# Leave empty to use the default AWS credentials chain (~/.aws/credentials)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_PROFILE=
